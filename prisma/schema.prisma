generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  password     String?
  role         Role      @default(EDITOR)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  avatar       String?
  bio          String?
  phone        String?
  twoFaEnabled Boolean   @default(false)
  twoFaSecret  String?
  isPublic     Boolean   @default(true)
  linkedIn     String?
  order        Int       @default(0)
  position     String?
  slug         String?   @unique
  teamType     TeamType?
  blogs        Blog[]
}

model Category {
  id           String        @id @default(cuid())
  name         String        @unique
  slug         String        @unique
  createdAt    DateTime      @default(now())
  blogs        Blog[]
  galleryItems GalleryItem[]
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  blogs     Blog[]   @relation("BlogToTag")
}

model Blog {
  id            String     @id @default(cuid())
  title         String
  slug          String     @unique
  content       String
  excerpt       String?
  featuredImage String?
  authorId      String?
  status        BlogStatus @default(DRAFT)
  publishedAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  categoryId    String?
  author        User?      @relation(fields: [authorId], references: [id])
  category      Category?  @relation(fields: [categoryId], references: [id])
  tags          Tag[]      @relation("BlogToTag")
}

model GalleryItem {
  id          String    @id @default(cuid())
  title       String
  description String?
  images      Json
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
}

model Contact {
  id        String        @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  status    ContactStatus @default(NEW)
  createdAt DateTime      @default(now())
}

model Media {
  id        String   @id @default(cuid())
  filename  String
  url       String
  mimeType  String
  size      Int
  alt       String?
  createdAt DateTime @default(now())
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String?
  text      String
  stars     Int      @default(5)
  isPublic  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  image     String?
}

model CarouselSlide {
  id        String   @id @default(cuid())
  image     String
  label     String
  title     String?
  subtitle  String?
  link      String?
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  ADMIN
  EDITOR
}

enum BlogStatus {
  DRAFT
  PUBLISHED
}

enum ContactStatus {
  NEW
  VIEWED
  RESPONDED
  CLOSED
}

enum TeamType {
  BOARD
  MANAGEMENT
}
